# Production identity and listener
CODEX_GATEWAY_ENV=production
CODEX_GATEWAY_BIND=0.0.0.0:8080
CODEX_GATEWAY_PUBLIC_URL=https://gateway.example.com

# Persistent SQLite database
CODEX_GATEWAY_DATABASE_URL=sqlite://data/codex-gateway.db

# Replace before first start. Keep APP_SECRET stable across restarts.
CODEX_GATEWAY_APP_SECRET=replace-with-at-least-32-random-characters
CODEX_GATEWAY_SECRET_KEY_VERSION=1

# Optional initial administrator. Remove the password and bootstrap key from the
# runtime environment after the first successful start.
CODEX_GATEWAY_ADMIN_EMAIL=admin@example.com
CODEX_GATEWAY_ADMIN_PASSWORD=replace-with-a-strong-password
CODEX_GATEWAY_BOOTSTRAP_ADMIN_KEY=cgk_live_adminprefix_replace_with_random_secret

# Browser origins in addition to PUBLIC_URL, comma-separated. Same-origin panel
# deployments can leave this empty.
CODEX_GATEWAY_PANEL_ORIGINS=

# Routing and upstream behavior
CODEX_GATEWAY_ROUTE_STRATEGY=priority
CODEX_GATEWAY_DEFAULT_REQUEST_TIMEOUT_MS=120000
CODEX_GATEWAY_MAX_REQUEST_BODY_BYTES=10485760
CODEX_GATEWAY_HEALTH_CHECKS_ENABLED=true
CODEX_GATEWAY_HEALTH_CHECK_INTERVAL_MS=30000

# Logs, retention, and diagnostics
CODEX_GATEWAY_LOG_LEVEL=info
CODEX_GATEWAY_REQUEST_LOG_RETENTION_DAYS=90
CODEX_GATEWAY_DAILY_USAGE_RETENTION_DAYS=730
CODEX_GATEWAY_RETENTION_RUN_ON_STARTUP=true
CODEX_GATEWAY_EXPOSE_DEBUG_HEADERS=false
